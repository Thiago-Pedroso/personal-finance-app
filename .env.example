# Credenciais da Pluggy (https://dashboard.pluggy.ai) — copie para .env e preencha.
# NUNCA commite o arquivo .env preenchido.

CLIENT_ID=seu_client_id_aqui
CLIENT_SECRET=seu_client_secret_aqui

# IDs dos "items" (conexões) conectados via Pluggy Connect / Meu Pluggy.
# Separados por vírgula. Ex.: ITEM_IDS=uuid-1,uuid-2
ITEM_IDS=
